default_platform(:ios)

platform :ios do

  desc "Build, archive and upload to TestFlight"
  lane :upload do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_content: ENV["APP_STORE_KEY_CONTENT"],
      key_filepath: ENV["APP_STORE_KEY_PATH"],
      is_key_content_base64: true
    )

    # Fresh App Store provisioning profile download karo
    profile = get_provisioning_profile(
      api_key: api_key,
      app_identifier: ENV["APP_IDENTIFIER"],
      force: true
    )

    # Project ko manual signing pe switch karo correct profile k sath
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "FastlaneSetup.xcodeproj",
      team_id: ENV["TEAM_ID"],
      bundle_identifier: ENV["APP_IDENTIFIER"],
      code_sign_identity: "Apple Distribution",
      profile_name: ENV["SIGH_PROFILE_NAME"]
    )

    gym(
      project: "FastlaneSetup.xcodeproj",
      scheme: "FastlaneSetup",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "FastlaneSetup.ipa",
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "./build/FastlaneSetup.ipa",
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build, archive and submit to App Store for review"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_content: ENV["APP_STORE_KEY_CONTENT"],
      key_filepath: ENV["APP_STORE_KEY_PATH"],
      is_key_content_base64: true
    )

    # Fresh App Store provisioning profile download karo
    profile = get_provisioning_profile(
      api_key: api_key,
      app_identifier: ENV["APP_IDENTIFIER"],
      force: true
    )

    # Project ko manual signing pe switch karo correct profile k sath
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "FastlaneSetup.xcodeproj",
      team_id: ENV["TEAM_ID"],
      bundle_identifier: ENV["APP_IDENTIFIER"],
      code_sign_identity: "Apple Distribution",
      profile_name: ENV["SIGH_PROFILE_NAME"]
    )

    gym(
      project: "FastlaneSetup.xcodeproj",
      scheme: "FastlaneSetup",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "FastlaneSetup.ipa",
      clean: true
    )

    upload_to_app_store(
      api_key: api_key,
      ipa: "./build/FastlaneSetup.ipa",
      submit_for_review: true,
      automatic_release: false,
      skip_metadata: true,
      skip_screenshots: true,
      force: true
    )
  end

end
