default_platform(:ios)

platform :ios do

  desc "Build, archive and upload to TestFlight"
  lane :upload do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_content: ENV["APP_STORE_KEY_CONTENT"],
      key_filepath: ENV["APP_STORE_KEY_PATH"],
      is_key_content_base64: true
    )

    gym(
      project: "FastlaneSetup.xcodeproj",
      scheme: "FastlaneSetup",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        signingStyle: "automatic",
        teamID: ENV["TEAM_ID"]
      },
      output_directory: "./build",
      output_name: "FastlaneSetup.ipa",
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "./build/FastlaneSetup.ipa",
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build, archive and submit to App Store for review"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_content: ENV["APP_STORE_KEY_CONTENT"],
      key_filepath: ENV["APP_STORE_KEY_PATH"],
      is_key_content_base64: true
    )

    gym(
      project: "FastlaneSetup.xcodeproj",
      scheme: "FastlaneSetup",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        signingStyle: "automatic",
        teamID: ENV["TEAM_ID"]
      },
      output_directory: "./build",
      output_name: "FastlaneSetup.ipa",
      clean: true
    )

    upload_to_app_store(
      api_key: api_key,
      ipa: "./build/FastlaneSetup.ipa",
      submit_for_review: true,
      automatic_release: false,
      skip_metadata: true,
      skip_screenshots: true,
      force: true
    )
  end

end
