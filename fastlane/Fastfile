default_platform(:ios)

platform :ios do

  desc "Build, archive and upload to TestFlight"
  lane :upload do
    app_id = ENV["APP_IDENTIFIER"].to_s.strip
    team = ENV["TEAM_ID"].to_s.strip

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"].to_s.strip,
      issuer_id: ENV["APP_STORE_ISSUER_ID"].to_s.strip,
      key_content: ENV["APP_STORE_KEY_CONTENT"],
      key_filepath: ENV["APP_STORE_KEY_PATH"],
      is_key_content_base64: true
    )

    # Fresh provisioning profile download karo
    get_provisioning_profile(
      api_key: api_key,
      app_identifier: app_id,
      force: true
    )

    # Manual signing set karo with downloaded profile
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "FastlaneSetup.xcodeproj",
      team_id: team,
      bundle_identifier: app_id,
      code_sign_identity: "Apple Distribution",
      profile_name: ENV["SIGH_NAME"]
    )

    gym(
      project: "FastlaneSetup.xcodeproj",
      scheme: "FastlaneSetup",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          app_id => ENV["SIGH_NAME"]
        }
      },
      output_directory: "./build",
      output_name: "FastlaneSetup.ipa",
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "./build/FastlaneSetup.ipa",
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build, archive and submit to App Store for review"
  lane :release do
    app_id = ENV["APP_IDENTIFIER"].to_s.strip
    team = ENV["TEAM_ID"].to_s.strip

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"].to_s.strip,
      issuer_id: ENV["APP_STORE_ISSUER_ID"].to_s.strip,
      key_content: ENV["APP_STORE_KEY_CONTENT"],
      key_filepath: ENV["APP_STORE_KEY_PATH"],
      is_key_content_base64: true
    )

    # Fresh provisioning profile download karo
    get_provisioning_profile(
      api_key: api_key,
      app_identifier: app_id,
      force: true
    )

    # Manual signing set karo with downloaded profile
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "FastlaneSetup.xcodeproj",
      team_id: team,
      bundle_identifier: app_id,
      code_sign_identity: "Apple Distribution",
      profile_name: ENV["SIGH_NAME"]
    )

    gym(
      project: "FastlaneSetup.xcodeproj",
      scheme: "FastlaneSetup",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          app_id => ENV["SIGH_NAME"]
        }
      },
      output_directory: "./build",
      output_name: "FastlaneSetup.ipa",
      clean: true
    )

    upload_to_app_store(
      api_key: api_key,
      ipa: "./build/FastlaneSetup.ipa",
      submit_for_review: true,
      automatic_release: false,
      skip_metadata: true,
      skip_screenshots: true,
      force: true
    )
  end

end
